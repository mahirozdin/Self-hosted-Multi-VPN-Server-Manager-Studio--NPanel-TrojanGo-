{
  "name": "npanel-manager-studio",
  "version": "1.0.0",
  "description": "Self-hosted control plane for NPanel/Trojan-Go VPN nodes: an SSH provisioning + monitoring studio and a multi-tenant, attested mobile VPN backend (/v1 API).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "migrate": "node src/migrations/cli.js up",
    "migrate:status": "node src/migrations/cli.js pending",
    "migrate:down": "node src/migrations/cli.js down"
  },
  "keywords": [
    "npanel",
    "vpn-manager",
    "trojan-go",
    "server-automation",
    "ssh-management"
  ],
  "author": "Mahir Taha Özdin",
  "license": "MIT",
  "dependencies": {
    "appattest-checker-node": "^1.0.3",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "mysql2": "^3.11.0",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "ssh2": "^1.17.0",
    "tcp-ping": "^0.1.1",
    "umzug": "^3.8.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yargs": "^18.0.0"
  },
  "type": "commonjs"
}
