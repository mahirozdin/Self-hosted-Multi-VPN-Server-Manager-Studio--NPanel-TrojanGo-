# ---- Admin panel ----
# Admin panel access password (plaintext). Prefer ADMIN_PASSWORD_HASH below.
ADMIN_PASSWORD=admin123
# Optional bcrypt hash of the admin password. When set it takes precedence over
# ADMIN_PASSWORD (which can then be left unset). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_PASSWORD_HASH=
# Random 32+ byte secret for signing admin session tokens.
# Required: if neither this nor ADMIN_PASSWORD is set, admin token creation fails.
ADMIN_SESSION_SECRET=replace-with-random-32-byte-secret

# Server listening port
PORT=3210

# ---- Database ----
# mysql (production) or sqlite (local/dev/test without MySQL)
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=npanel
DB_PASSWORD=
DB_NAME=npanel
# Only used when DB_DIALECT=sqlite
SQLITE_STORAGE=database.sqlite
# Connection pool (MySQL). Raise DB_POOL_MAX for scale, in tandem with mysqld
# max_connections. Defaults: max 10, min 0, acquire 30000ms, idle 10000ms.
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
# Migrations: leave unset in production and run "npm run migrate" as an explicit
# deploy step (safer with multiple instances / large tables). Set to true only
# for single-instance/dev to auto-apply pending migrations on boot.
AUTO_MIGRATE=

# 32-byte hex key (64 hex chars) encrypting secrets at rest
# (server SSH passwords, NPanel admin passwords, per-app HMAC secrets).
# Generate with: openssl rand -hex 32
# WARNING: losing this key makes encrypted columns unrecoverable.
DB_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ---- Networking / proxy ----
# Trusted proxy hop count (Cloudflare->Node = 1, Cloudflare->nginx->Node = 2).
# Never use 'true'. CF-Connecting-IP remains the source of truth for client IP.
TRUST_PROXY_HOPS=1
# Comma-separated CORS origins for the admin panel (optional; same-origin needs none).
ADMIN_ORIGIN=
# Secret admin-panel path (obscurity gate). When set, the panel is hidden at the
# root: only visiting https://host/<value> lets you in (sets a cookie, redirects
# to the login). Everything else 404s so scanners can't find the login page.
# Pick something long/random, e.g. a1b2c3d4e5. Leave empty to serve the panel at /.
ADMIN_PANEL_PATH=
# Cloudflare origin trust. When true, /v1 requests whose immediate peer is not a
# published Cloudflare edge are rejected (403) and CF-Connecting-IP is only
# trusted from a Cloudflare peer. Leave false for local/dev (default false).
CF_ENFORCE=false

# ---- Mobile API ----
# development accepts mock attestation tokens for local mobile API tests.
# Use strict for real iOS App Attest / Android Play Integrity validation.
# RECOMMENDED: set to strict in production (development mode accepts mock tokens).
MOBILE_ATTESTATION_MODE=development
# Rate limits (per 60s window). DEVICE_MAX is the real per-user cap; IP_MAX is
# the shared anti-flood ceiling and must stay high enough that carrier-grade NAT
# (many real users behind one egress IP) doesn't trip it. Defaults: 90 / 3000.
RATE_LIMIT_DEVICE_MAX=90
RATE_LIMIT_IP_MAX=3000
# Directory holding per-tenant Play Integrity service-account JSON files.
# The App row references one by filename (play_integrity_sa_ref). Apple App
# Attest needs no server secret (verified locally against the bundled root CA).
GOOGLE_APPLICATION_CREDENTIALS_DIR=

# ---- Retention (cleanup jobs) ----
# Days to keep API audit logs before the daily purge (default 90).
AUDIT_LOG_RETENTION_DAYS=90
# Days to keep connection logs before the daily purge (default 365).
CONNECTION_LOG_RETENTION_DAYS=365

# ---- Email alerts (SMTP) ----
# Health/cert/provisioning alerts are emailed when a server goes down, a cert
# renewal fails, etc. Leave SMTP_HOST empty to disable email (alerts are then
# only shown in the panel). The recipient is set in the panel Settings page
# (alert_email); ALERT_EMAIL_TO is the fallback used if that is empty.
SMTP_HOST=
SMTP_PORT=587
# true for port 465 (implicit TLS); false/omit for 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address (defaults to SMTP_USER when omitted).
SMTP_FROM=
# Fallback alert recipient if none is set in the panel Settings page.
ALERT_EMAIL_TO=
